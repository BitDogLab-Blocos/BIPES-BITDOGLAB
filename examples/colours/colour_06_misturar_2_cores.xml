<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Mistura de 2 cores: vermelho + azul = roxo, vermelho + verde = amarelo, azul + verde = ciano — cada par de primarias cria uma secundaria -->
  <block type="bloco_ligar_led" x="20" y="20">
    <value name="COLOUR">
      <block type="mix_colours">
        <mutation items="2"></mutation>
        <value name="ADD0">
          <block type="colour_red"></block>
        </value>
        <value name="ADD1">
          <block type="colour_blue"></block>
        </value>
      </block>
    </value>
    <next>
      <block type="esperar_segundos">
        <value name="TIME">
          <block type="math_number"><field name="NUM">2</field></block>
        </value>
        <next>
          <block type="bloco_ligar_led">
            <value name="COLOUR">
              <block type="mix_colours">
                <mutation items="2"></mutation>
                <value name="ADD0">
                  <block type="colour_red"></block>
                </value>
                <value name="ADD1">
                  <block type="colour_green"></block>
                </value>
              </block>
            </value>
            <next>
              <block type="esperar_segundos">
                <value name="TIME">
                  <block type="math_number"><field name="NUM">2</field></block>
                </value>
                <next>
                  <block type="bloco_ligar_led">
                    <value name="COLOUR">
                      <block type="mix_colours">
                        <mutation items="2"></mutation>
                        <value name="ADD0">
                          <block type="colour_blue"></block>
                        </value>
                        <value name="ADD1">
                          <block type="colour_green"></block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="esperar_segundos">
                        <value name="TIME">
                          <block type="math_number"><field name="NUM">2</field></block>
                        </value>
                        <next>
                          <block type="bloco_desligar_todos_leds"></block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
