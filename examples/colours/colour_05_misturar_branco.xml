<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Criar branco misturando: vermelho + verde + azul juntos = branco — a crianca descobre que todas as cores de luz misturadas formam branco -->
  <block type="bloco_ligar_led" x="20" y="20">
    <value name="COLOUR">
      <block type="mix_colours">
        <mutation items="3"></mutation>
        <value name="ADD0">
          <block type="colour_red"></block>
        </value>
        <value name="ADD1">
          <block type="colour_green"></block>
        </value>
        <value name="ADD2">
          <block type="colour_blue"></block>
        </value>
      </block>
    </value>
    <next>
      <block type="esperar_segundos">
        <value name="TIME">
          <block type="math_number"><field name="NUM">3</field></block>
        </value>
        <next>
          <block type="bloco_desligar_todos_leds"></block>
        </next>
      </block>
    </next>
  </block>
</xml>
