<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Cores frias: azul, ciano e verde em sequencia — a crianca sente a "frieza" dessas cores -->
  <block type="bloco_ligar_led" x="20" y="20">
    <value name="COLOUR">
      <block type="colour_blue"></block>
    </value>
    <next>
      <block type="esperar_segundos">
        <value name="TIME">
          <block type="math_number"><field name="NUM">2</field></block>
        </value>
        <next>
          <block type="bloco_ligar_led">
            <value name="COLOUR">
              <block type="colour_cyan"></block>
            </value>
            <next>
              <block type="esperar_segundos">
                <value name="TIME">
                  <block type="math_number"><field name="NUM">2</field></block>
                </value>
                <next>
                  <block type="bloco_ligar_led">
                    <value name="COLOUR">
                      <block type="colour_green"></block>
                    </value>
                    <next>
                      <block type="esperar_segundos">
                        <value name="TIME">
                          <block type="math_number"><field name="NUM">2</field></block>
                        </value>
                        <next>
                          <block type="bloco_desligar_todos_leds"></block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
