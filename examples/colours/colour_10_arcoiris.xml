<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Arco-iris completo: vermelho → amarelo → verde → ciano → azul → magenta → vermelho — todas as cores do arco-iris em transicoes suaves -->
  <block type="bloco_transicao_led" x="20" y="20">
    <value name="COLOUR1">
      <block type="colour_red"></block>
    </value>
    <value name="COLOUR2">
      <block type="colour_yellow"></block>
    </value>
    <next>
      <block type="bloco_transicao_led">
        <value name="COLOUR1">
          <block type="colour_yellow"></block>
        </value>
        <value name="COLOUR2">
          <block type="colour_green"></block>
        </value>
        <next>
          <block type="bloco_transicao_led">
            <value name="COLOUR1">
              <block type="colour_green"></block>
            </value>
            <value name="COLOUR2">
              <block type="colour_cyan"></block>
            </value>
            <next>
              <block type="bloco_transicao_led">
                <value name="COLOUR1">
                  <block type="colour_cyan"></block>
                </value>
                <value name="COLOUR2">
                  <block type="colour_blue"></block>
                </value>
                <next>
                  <block type="bloco_transicao_led">
                    <value name="COLOUR1">
                      <block type="colour_blue"></block>
                    </value>
                    <value name="COLOUR2">
                      <block type="colour_magenta"></block>
                    </value>
                    <next>
                      <block type="bloco_transicao_led">
                        <value name="COLOUR1">
                          <block type="colour_magenta"></block>
                        </value>
                        <value name="COLOUR2">
                          <block type="colour_red"></block>
                        </value>
                        <next>
                          <block type="bloco_desligar_todos_leds"></block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
