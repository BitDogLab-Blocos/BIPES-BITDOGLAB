<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Vaga-lume: fade verde 3x, pausa, depois fade ciano 3x - como dois vaga-lumes diferentes -->
  <block type="controls_repeat_simple" x="20" y="20">
    <field name="TIMES">3</field>
    <statement name="DO">
      <block type="bloco_animar_led_brilhar">
        <value name="COLOUR">
          <block type="colour_green"></block>
        </value>
      </block>
    </statement>
    <next>
      <block type="bloco_desligar_todos_leds">
        <next>
          <block type="esperar_segundos">
            <value name="TIME">
              <block type="math_number">
                <field name="NUM">2</field>
              </block>
            </value>
            <next>
              <block type="controls_repeat_simple">
                <field name="TIMES">3</field>
                <statement name="DO">
                  <block type="bloco_animar_led_brilhar">
                    <value name="COLOUR">
                      <block type="colour_cyan"></block>
                    </value>
                  </block>
                </statement>
                <next>
                  <block type="bloco_desligar_todos_leds"></block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
