<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Amanhecer: brilho do azul vai aumentando aos poucos como o sol nascendo -->
  <block type="bloco_acender_led_brilho" x="20" y="20">
    <field name="INTENSITY">10</field>
    <value name="COLOUR">
      <block type="colour_blue"></block>
    </value>
    <next>
      <block type="esperar_segundos">
        <value name="TIME">
          <block type="math_number">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="bloco_acender_led_brilho">
            <field name="INTENSITY">30</field>
            <value name="COLOUR">
              <block type="colour_blue"></block>
            </value>
            <next>
              <block type="esperar_segundos">
                <value name="TIME">
                  <block type="math_number">
                    <field name="NUM">1</field>
                  </block>
                </value>
                <next>
                  <block type="bloco_acender_led_brilho">
                    <field name="INTENSITY">60</field>
                    <value name="COLOUR">
                      <block type="colour_blue"></block>
                    </value>
                    <next>
                      <block type="esperar_segundos">
                        <value name="TIME">
                          <block type="math_number">
                            <field name="NUM">1</field>
                          </block>
                        </value>
                        <next>
                          <block type="bloco_acender_led_brilho">
                            <field name="INTENSITY">100</field>
                            <value name="COLOUR">
                              <block type="colour_blue"></block>
                            </value>
                            <next>
                              <block type="esperar_segundos">
                                <value name="TIME">
                                  <block type="math_number">
                                    <field name="NUM">2</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="bloco_desligar_todos_leds"></block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
