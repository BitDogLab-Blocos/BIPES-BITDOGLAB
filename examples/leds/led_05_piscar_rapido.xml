<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Alarme: pisca vermelho rapido 5x, pausa, pisca azul rapido 5x -->
  <block type="controls_repeat_simple" x="20" y="20">
    <field name="TIMES">5</field>
    <statement name="DO">
      <block type="bloco_piscar_led">
        <value name="COLOUR">
          <block type="colour_red"></block>
        </value>
      </block>
    </statement>
    <next>
      <block type="esperar_segundos">
        <value name="TIME">
          <block type="math_number">
            <field name="NUM">2</field>
          </block>
        </value>
        <next>
          <block type="controls_repeat_simple">
            <field name="TIMES">5</field>
            <statement name="DO">
              <block type="bloco_piscar_led">
                <value name="COLOUR">
                  <block type="colour_blue"></block>
                </value>
              </block>
            </statement>
            <next>
              <block type="esperar_segundos">
                <value name="TIME">
                  <block type="math_number">
                    <field name="NUM">1</field>
                  </block>
                </value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
