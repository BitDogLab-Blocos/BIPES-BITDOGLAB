<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Festa de cores: alterna entre 3 cores 8 vezes - como uma festa! -->
  <block type="controls_repeat_simple" x="20" y="20">
    <field name="TIMES">8</field>
    <statement name="DO">
      <block type="bloco_alternar_led">
        <mutation items="3"></mutation>
        <value name="COLOUR0">
          <block type="colour_red"></block>
        </value>
        <value name="COLOUR1">
          <block type="colour_green"></block>
        </value>
        <value name="COLOUR2">
          <block type="colour_blue"></block>
        </value>
      </block>
    </statement>
    <next>
      <block type="bloco_desligar_todos_leds">
        <next>
          <block type="esperar_segundos">
            <value name="TIME">
              <block type="math_number">
                <field name="NUM">1</field>
              </block>
            </value>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
