<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Temporizador: espera um segundo, soma um e mostra a memoria no OLED. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">segundos</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">0</field>
      </block>
    </value>
    <next>
      <block type="esperar_segundos">
        <value name="TIME">
          <block type="math_number">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variables_adicionar">
            <field name="VAR">segundos</field>
            <value name="AMOUNT">
              <block type="math_number">
                <field name="NUM">1</field>
              </block>
            </value>
            <next>
              <block type="display_mostrar_valor">
                <field name="LINHA">1</field>
                <field name="ALINHAMENTO">CENTER</field>
                <value name="VALOR">
                  <block type="variables_valor_guardado">
                    <field name="VAR">segundos</field>
                  </block>
                </value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
