<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Barra de nivel: os botoes mudam nivel e cada faixa acende mais linhas da matriz. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">nivel</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">0</field>
      </block>
    </value>
    <next>
      <block type="botao_se_apertado">
        <field name="BOTAO">A</field>
        <statement name="DO">
          <block type="variables_adicionar">
            <field name="VAR">nivel</field>
            <value name="AMOUNT">
              <block type="math_number">
                <field name="NUM">1</field>
              </block>
            </value>
          </block>
        </statement>
        <next>
          <block type="botao_se_apertado">
            <field name="BOTAO">B</field>
            <statement name="DO">
              <block type="variables_tirar">
                <field name="VAR">nivel</field>
                <value name="AMOUNT">
                  <block type="math_number">
                    <field name="NUM">1</field>
                  </block>
                </value>
              </block>
            </statement>
            <next>
              <block type="controls_if">
                <value name="IF0">
                  <block type="logic_compare">
                    <field name="OP">GTE</field>
                    <value name="A">
                      <block type="variables_valor_guardado">
                        <field name="VAR">nivel</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number">
                        <field name="NUM">1</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="acender_linha">
                    <field name="LINHA">4</field>
                    <field name="INTENSITY">30</field>
                    <value name="COLOUR">
                      <block type="colour_green"></block>
                    </value>
                  </block>
                </statement>
                <next>
                  <block type="controls_if">
                    <value name="IF0">
                      <block type="logic_compare">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="variables_valor_guardado">
                            <field name="VAR">nivel</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number">
                            <field name="NUM">3</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="acender_linha">
                        <field name="LINHA">2</field>
                        <field name="INTENSITY">30</field>
                        <value name="COLOUR">
                          <block type="colour_yellow"></block>
                        </value>
                      </block>
                    </statement>
                    <next>
                      <block type="controls_if">
                        <value name="IF0">
                          <block type="logic_compare">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="variables_valor_guardado">
                                <field name="VAR">nivel</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number">
                                <field name="NUM">5</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="acender_linha">
                            <field name="LINHA">0</field>
                            <field name="INTENSITY">30</field>
                            <value name="COLOUR">
                              <block type="colour_red"></block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
