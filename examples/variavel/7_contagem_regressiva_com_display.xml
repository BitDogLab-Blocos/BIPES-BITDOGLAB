<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Contagem regressiva: A tira uma unidade; ao chegar a zero o LED vermelho acende. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">contador</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">10</field>
      </block>
    </value>
    <next>
      <block type="botao_se_apertado">
        <field name="BOTAO">A</field>
        <statement name="DO">
          <block type="variables_tirar">
            <field name="VAR">contador</field>
            <value name="AMOUNT">
              <block type="math_number">
                <field name="NUM">1</field>
              </block>
            </value>
          </block>
        </statement>
        <next>
          <block type="display_mostrar_valor">
            <field name="LINHA">1</field>
            <field name="ALINHAMENTO">CENTER</field>
            <value name="VALOR">
              <block type="variables_valor_guardado">
                <field name="VAR">contador</field>
              </block>
            </value>
            <next>
              <block type="controls_if">
                <value name="IF0">
                  <block type="logic_compare">
                    <field name="OP">LTE</field>
                    <value name="A">
                      <block type="variables_valor_guardado">
                        <field name="VAR">contador</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number">
                        <field name="NUM">0</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="bloco_ligar_led">
                    <value name="COLOUR">
                      <block type="colour_red"></block>
                    </value>
                  </block>
                </statement>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
