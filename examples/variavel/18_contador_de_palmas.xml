<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Palmas: o microfone atualiza som; cada pico adiciona uma palma e o OLED mostra o total. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">som</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">0</field>
      </block>
    </value>
    <next>
      <block type="variables_guardar">
        <field name="VAR">palmas</field>
        <value name="VALUE">
          <block type="math_number">
            <field name="NUM">0</field>
          </block>
        </value>
        <next>
          <block type="microfone_vu_meter">
            <field name="BRILHO">30</field>
            <value name="COR">
              <block type="colour_blue" />
            </value>
            <next>
              <block type="variables_alterar">
                <field name="VAR">som</field>
                <value name="TARGET">
                  <block type="variables_valor_guardado">
                    <field name="VAR">som</field>
                  </block>
                </value>
                <value name="VALUE">
                  <block type="microfone_nivel_atual"></block>
                </value>
                <next>
                  <block type="controls_if">
                    <value name="IF0">
                      <block type="logic_compare">
                        <field name="OP">GT</field>
                        <value name="A">
                          <block type="variables_valor_guardado">
                            <field name="VAR">som</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number">
                            <field name="NUM">3</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="variables_adicionar">
                        <field name="VAR">palmas</field>
                        <value name="AMOUNT">
                          <block type="math_number">
                            <field name="NUM">1</field>
                          </block>
                        </value>
                        <next>
                          <block type="esperar_milisegundos">
                            <value name="TIME">
                              <block type="math_number">
                                <field name="NUM">250</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="display_mostrar_valor">
                        <field name="LINHA">1</field>
                        <field name="ALINHAMENTO">CENTER</field>
                        <value name="VALOR">
                          <block type="variables_valor_guardado">
                            <field name="VAR">palmas</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
