<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Velocidade: os botoes mudam tempo e a faixa escolhe piscar rapido ou devagar. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">tempo</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">500</field>
      </block>
    </value>
    <next>
      <block type="botao_se_apertado">
        <field name="BOTAO">A</field>
        <statement name="DO">
          <block type="variables_tirar">
            <field name="VAR">tempo</field>
            <value name="AMOUNT">
              <block type="math_number">
                <field name="NUM">50</field>
              </block>
            </value>
          </block>
        </statement>
        <next>
          <block type="botao_se_apertado">
            <field name="BOTAO">B</field>
            <statement name="DO">
              <block type="variables_adicionar">
                <field name="VAR">tempo</field>
                <value name="AMOUNT">
                  <block type="math_number">
                    <field name="NUM">50</field>
                  </block>
                </value>
              </block>
            </statement>
            <next>
              <block type="controls_ifelse">
                <value name="IF0">
                  <block type="logic_compare">
                    <field name="OP">LTE</field>
                    <value name="A">
                      <block type="variables_valor_guardado">
                        <field name="VAR">tempo</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number">
                        <field name="NUM">300</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="matriz_piscar_rapido">
                    <statement name="DO">
                      <block type="preencher_matriz">
                        <field name="INTENSITY">30</field>
                        <value name="COLOUR">
                          <block type="colour_blue"></block>
                        </value>
                      </block>
                    </statement>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="matriz_piscar_lento">
                    <statement name="DO">
                      <block type="preencher_matriz">
                        <field name="INTENSITY">30</field>
                        <value name="COLOUR">
                          <block type="colour_blue"></block>
                        </value>
                      </block>
                    </statement>
                  </block>
                </statement>
                <next>
                  <block type="display_mostrar_valor">
                    <field name="LINHA">1</field>
                    <field name="ALINHAMENTO">LEFT</field>
                    <value name="VALOR">
                      <block type="variables_valor_guardado">
                        <field name="VAR">tempo</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
