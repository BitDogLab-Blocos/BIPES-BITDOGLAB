<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Alerta sonoro: o microfone atualiza som; acima do limite o LED vermelho acende. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">som</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">0</field>
      </block>
    </value>
    <next>
      <block type="microfone_vu_meter">
        <field name="BRILHO">30</field>
        <value name="COR">
          <block type="colour_blue" />
        </value>
        <next>
          <block type="variables_alterar">
            <field name="VAR">som</field>
            <value name="TARGET">
              <block type="variables_valor_guardado">
                <field name="VAR">som</field>
              </block>
            </value>
            <value name="VALUE">
              <block type="microfone_nivel_atual"></block>
            </value>
            <next>
              <block type="controls_ifelse">
                <value name="IF0">
                  <block type="logic_compare">
                    <field name="OP">GT</field>
                    <value name="A">
                      <block type="variables_valor_guardado">
                        <field name="VAR">som</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number">
                        <field name="NUM">3</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="bloco_ligar_led">
                    <value name="COLOUR">
                      <block type="colour_red"></block>
                    </value>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="bloco_desligar_todos_leds"></block>
                </statement>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
