<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Pontuacao: pontos recebe acertos vezes dez menos erros vezes dois apos cada botao. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">acertos</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">0</field>
      </block>
    </value>
    <next>
      <block type="variables_guardar">
        <field name="VAR">erros</field>
        <value name="VALUE">
          <block type="math_number">
            <field name="NUM">0</field>
          </block>
        </value>
        <next>
          <block type="variables_guardar">
            <field name="VAR">pontos</field>
            <value name="VALUE">
              <block type="math_number">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="botao_se_apertado">
                <field name="BOTAO">A</field>
                <statement name="DO">
                  <block type="variables_adicionar">
                    <field name="VAR">acertos</field>
                    <value name="AMOUNT">
                      <block type="math_number">
                        <field name="NUM">1</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_alterar">
                        <field name="VAR">pontos</field>
                        <value name="TARGET">
                          <block type="variables_valor_guardado">
                            <field name="VAR">pontos</field>
                          </block>
                        </value>
                        <value name="VALUE">
                          <block type="math_arithmetic">
                            <field name="OP">MINUS</field>
                            <value name="A">
                              <block type="math_arithmetic">
                                <field name="OP">MULTIPLY</field>
                                <value name="A">
                                  <block type="variables_valor_guardado">
                                    <field name="VAR">acertos</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="math_number">
                                    <field name="NUM">10</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_arithmetic">
                                <field name="OP">MULTIPLY</field>
                                <value name="A">
                                  <block type="variables_valor_guardado">
                                    <field name="VAR">erros</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="math_number">
                                    <field name="NUM">2</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
                <next>
                  <block type="botao_se_apertado">
                    <field name="BOTAO">B</field>
                    <statement name="DO">
                      <block type="variables_adicionar">
                        <field name="VAR">erros</field>
                        <value name="AMOUNT">
                          <block type="math_number">
                            <field name="NUM">1</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_alterar">
                            <field name="VAR">pontos</field>
                            <value name="TARGET">
                              <block type="variables_valor_guardado">
                                <field name="VAR">pontos</field>
                              </block>
                            </value>
                            <value name="VALUE">
                              <block type="math_arithmetic">
                                <field name="OP">MINUS</field>
                                <value name="A">
                                  <block type="math_arithmetic">
                                    <field name="OP">MULTIPLY</field>
                                    <value name="A">
                                      <block type="variables_valor_guardado">
                                        <field name="VAR">acertos</field>
                                      </block>
                                    </value>
                                    <value name="B">
                                      <block type="math_number">
                                        <field name="NUM">10</field>
                                      </block>
                                    </value>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="math_arithmetic">
                                    <field name="OP">MULTIPLY</field>
                                    <value name="A">
                                      <block type="variables_valor_guardado">
                                        <field name="VAR">erros</field>
                                      </block>
                                    </value>
                                    <value name="B">
                                      <block type="math_number">
                                        <field name="NUM">2</field>
                                      </block>
                                    </value>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="display_mostrar_valor">
                        <field name="LINHA">1</field>
                        <field name="ALINHAMENTO">CENTER</field>
                        <value name="VALOR">
                          <block type="variables_valor_guardado">
                            <field name="VAR">pontos</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
