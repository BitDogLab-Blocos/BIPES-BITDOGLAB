<xml xmlns="https://developers.google.com/blockly/xml">
  <!-- Maior temperatura: a leitura atual substitui o recorde somente quando for maior. -->
  <block type="variables_guardar" x="20" y="20">
    <field name="VAR">temperatura</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">0</field>
      </block>
    </value>
    <next>
      <block type="variables_guardar">
        <field name="VAR">maior_temperatura</field>
        <value name="VALUE">
          <block type="math_number">
            <field name="NUM">0</field>
          </block>
        </value>
        <next>
          <block type="variables_alterar">
            <field name="VAR">temperatura</field>
            <value name="TARGET">
              <block type="variables_valor_guardado">
                <field name="VAR">temperatura</field>
              </block>
            </value>
            <value name="VALUE">
              <block type="sensor_temperatura"></block>
            </value>
            <next>
              <block type="controls_if">
                <value name="IF0">
                  <block type="logic_compare">
                    <field name="OP">GT</field>
                    <value name="A">
                      <block type="variables_valor_guardado">
                        <field name="VAR">temperatura</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="variables_valor_guardado">
                        <field name="VAR">maior_temperatura</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="variables_alterar">
                    <field name="VAR">maior_temperatura</field>
                    <value name="TARGET">
                      <block type="variables_valor_guardado">
                        <field name="VAR">maior_temperatura</field>
                      </block>
                    </value>
                    <value name="VALUE">
                      <block type="variables_valor_guardado">
                        <field name="VAR">temperatura</field>
                      </block>
                    </value>
                  </block>
                </statement>
                <next>
                  <block type="display_mostrar_valor">
                    <field name="LINHA">1</field>
                    <field name="ALINHAMENTO">CENTER</field>
                    <value name="VALOR">
                      <block type="variables_valor_guardado">
                        <field name="VAR">maior_temperatura</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
